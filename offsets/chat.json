      "assertion_file": "\\Code\\Gw\\Ui\\Game\\GmChatLog.cpp",
      "assertion_message": "m_itemCount <= CHAT_LOG_SIZE",
      "line_number": "0",
      "offset": "0x0",
      "section": "text"
    },
    "is_typing_assertion": {
