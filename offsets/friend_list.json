{
  "namespace": "friend_list",
  "patterns": {
    "friend_list_anchor": {
      "assertion_file": "FriendApi.cpp",
      "assertion_message": "friendName && *friendName",
      "line_number": "0",
      "offset": "0",
      "range": "0xFF",
      "section": "text"
    },
    "friend_list_scan": {
      "pattern": "\\x57\\xB9",
      "mask": "xx",
      "offset": "0x2",
      "section": "text"
    },
    "friend_event_handler": {
      "pattern": "\\x83\\xC0\\xDA\\x83\\xF8\\x06",
      "mask": "xxxxxx",
      "offset": "0",
      "section": "text"
    },
    "set_online_status": {
      "pattern": "\\x83\\xFE\\x03\\x77\\x40\\xFF\\x24\\xB5\\x00\\x00\\x00\\x00\\x33\\xC0",
      "mask": "xxxxxxxx????xx",
      "offset": "0",
      "section": "text"
    },
    "add_friend": {
      "pattern": "\\x8B\\x75\\x10\\x83\\xFE\\x03\\x74\\x65",
      "mask": "xxxxxxxx",
      "offset": "0",
      "section": "text"
    },
    "remove_friend_anchor": {
      "pattern": "\\x83\\xF8\\x03\\x74\\x1D\\x83\\xF8\\x04\\x74\\x18",
      "mask": "xxxxxxxxxx",
      "offset": "0",
      "range": "0x32",
      "section": "text"
    },
    "remove_friend_call": {
      "pattern": "\\x50\\xE8",
      "mask": "xx",
      "offset": "0x1",
      "section": "text"
    }
  },
  "resolvers": {
    "friend_list_addr": {
      "steps": [
        { "name": "scan_anchor", "op": "scan", "pattern": "friend_list_anchor", "out": "anchor" },
        { "name": "scan_pointer_ref", "op": "scan_in_range", "pattern": "friend_list_scan", "start": "anchor", "end": "anchor", "end_add": "0xFF", "out": "pointer_ref" },
        { "name": "deref_ptr", "op": "dereference", "in": "pointer_ref", "out": "candidate" },
        { "name": "validate_ptr", "op": "validate_section", "in": "candidate", "section": "data", "out": "final" }
      ]
    },
    "friend_event_handler_func": {
      "steps": [
        { "name": "scan_target", "op": "scan", "pattern": "friend_event_handler", "out": "scan" },
        { "name": "to_function_start", "op": "to_function_start", "in": "scan", "out": "final" }
      ]
    },
    "set_online_status_func": {
      "steps": [
        { "name": "scan_target", "op": "scan", "pattern": "set_online_status", "out": "scan" },
        { "name": "to_function_start", "op": "to_function_start", "in": "scan", "out": "final" }
      ]
    },
    "add_friend_func": {
      "steps": [
        { "name": "scan_target", "op": "scan", "pattern": "add_friend", "out": "scan" },
        { "name": "to_function_start", "op": "to_function_start", "in": "scan", "out": "final" }
      ]
    },
    "remove_friend_func": {
      "steps": [
        { "name": "scan_anchor", "op": "scan", "pattern": "remove_friend_anchor", "out": "anchor" },
        { "name": "scan_callsite", "op": "scan_in_range", "pattern": "remove_friend_call", "start": "anchor", "end": "anchor", "end_add": "0x32", "out": "callsite" },
        { "name": "resolve_target", "op": "function_from_near_call", "in": "callsite", "out": "final" }
      ]
    }
  }
}
