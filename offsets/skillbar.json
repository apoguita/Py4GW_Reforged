{
  "namespace": "skillbar",
  "patterns": {
    "skill_array_ref": {
      "pattern": "\\xE8\\x00\\x00\\x00\\x00\\x33\\xC9\\x56",
      "mask": "x????xxx",
      "offset": "0x0",
      "section": "text"
    },
    "attribute_array_ref": {
      "pattern": "\\xba\\x33\\x00\\x00\\x00\\x89\\x08\\x8d\\x40\\x04",
      "mask": "x?xxxxxxxx",
      "offset": "-4",
      "section": "text"
    },
    "use_skill_func_callsite": {
      "pattern": "\\x85\\xF6\\x74\\x5B\\x83\\xFE\\x11\\x74",
      "mask": "xxxxxxxx",
      "offset": "0x0",
      "section": "text"
    },
    "templates_helpers_assertion": {
      "assertion_file": "TemplatesHelpers.cpp",
      "assertion_message": "targetPrimaryProf == templateData.profPrimary",
      "line_number": "0",
      "offset": "0x0",
      "section": "text"
    }
  },
  "resolvers": {
    "skill_array_addr": {
      "steps": [
        { "name": "scan_callsite", "op": "scan", "pattern": "skill_array_ref", "out": "callsite" },
        { "name": "resolve_helper", "op": "function_from_near_call", "in": "callsite", "out": "helper" },
        { "name": "validate_helper", "op": "validate_section", "in": "helper", "section": "text", "out": "helper_checked" },
        { "name": "array_ref", "op": "add", "in": "helper_checked", "value": "0x2B", "out": "array_ref" },
        { "name": "deref_ptr", "op": "dereference", "in": "array_ref", "out": "final" }
      ]
    },
    "attribute_array_addr": {
      "steps": [
        { "name": "scan_ref", "op": "scan", "pattern": "attribute_array_ref", "out": "scan" },
        { "name": "deref_ptr", "op": "dereference", "in": "scan", "out": "candidate" },
        { "name": "validate_ptr", "op": "validate_section", "in": "candidate", "section": "rdata", "out": "final" }
      ]
    },
    "use_skill_func": {
      "steps": [
        { "name": "scan_callsite", "op": "scan", "pattern": "use_skill_func_callsite", "out": "scan" },
        { "name": "to_function_start", "op": "to_function_start", "in": "scan", "scan_range": "0x200", "out": "final" }
      ]
    },
    "change_secondary_func": {
      "steps": [
        { "name": "scan_anchor", "op": "scan", "pattern": "templates_helpers_assertion", "out": "anchor" },
        { "name": "callsite_adjust", "op": "add", "in": "anchor", "value": "0x20", "out": "callsite" },
        { "name": "resolve_target", "op": "function_from_near_call", "in": "callsite", "out": "final" }
      ]
    },
    "load_attributes_func": {
      "steps": [
        { "name": "scan_anchor", "op": "scan", "pattern": "templates_helpers_assertion", "out": "anchor" },
        { "name": "callsite_adjust", "op": "add", "in": "anchor", "value": "0x34", "out": "callsite" },
        { "name": "resolve_target", "op": "function_from_near_call", "in": "callsite", "out": "final" }
      ]
    },
    "load_skills_func": {
      "steps": [
        { "name": "scan_anchor", "op": "scan", "pattern": "templates_helpers_assertion", "out": "anchor" },
        { "name": "callsite_adjust", "op": "add", "in": "anchor", "value": "0x40", "out": "callsite" },
        { "name": "resolve_target", "op": "function_from_near_call", "in": "callsite", "out": "final" }
      ]
    }
  }
}
