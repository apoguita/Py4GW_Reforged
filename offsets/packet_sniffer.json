{
  "namespace": "packet_sniffer",
  "patterns": {
    "ctos_send_wrapper": {
      "pattern": "\\xF7\\xD8\\xC7\\x47\\x54\\x01\\x00\\x00\\x00\\x1B\\xC0\\x25",
      "mask": "xxxxxxxxxxxx",
      "offset": "-0xBF",
      "section": "text"
    },
    "ctos_assert_bytes_dword": {
      "assertion_file": "MsgConn.cpp",
      "assertion_message": "bytes >= sizeof(dword)"
    },
    "ctos_assert_bytes_data": {
      "assertion_file": "MsgConn.cpp",
      "assertion_message": "bytes && data"
    }
  },
  "resolvers": {
    "ctos_send_target": {
      "log_level": "error",
      "on_fail": "continue",
      "attempts": [
        {
          "name": "primary_pattern",
          "steps": [
            { "name": "scan_wrapper", "op": "scan", "pattern": "ctos_send_wrapper", "out": "final" }
          ]
        },
        {
          "name": "assertion_bytes_dword",
          "steps": [
            { "name": "scan_assertion", "op": "scan", "pattern": "ctos_assert_bytes_dword", "out": "assert_addr" },
            { "name": "to_function_start", "op": "to_function_start", "in": "assert_addr", "out": "final" }
          ]
        },
        {
          "name": "assertion_bytes_data",
          "steps": [
            { "name": "scan_assertion", "op": "scan", "pattern": "ctos_assert_bytes_data", "out": "assert_addr" },
            { "name": "to_function_start", "op": "to_function_start", "in": "assert_addr", "out": "final" }
          ]
        }
      ]
    }
  }
}
