{
  "namespace": "gw_dat_reader",
  "patterns": {
    "decode_image_anchor": {
      "assertion_file": "GrImage.cpp",
      "assertion_message": "bits || !palette",
      "line_number": "0",
      "offset": "0x0",
      "section": "text"
    },
    "amet_data_anchor": {
      "assertion_file": "Amet.cpp",
      "assertion_message": "data",
      "line_number": "0",
      "offset": "0x0",
      "section": "text"
    },
    "amet_compare": {
      "pattern": "\\x81\\x3a\\x41\\x4d\\x45\\x54",
      "mask": "xxxxxx",
      "offset": "0x0",
      "section": "text"
    },
    "open_file_anchor": {
      "assertion_file": "File.cpp",
      "assertion_message": "!(flags & (FILE_OPEN_READ | FILE_OPEN_WRITE) & ~source.m_flags)",
      "line_number": "0",
      "offset": "0x0",
      "section": "text"
    },
    "allocate_image_pattern": {
      "pattern": "\\x7c\\x11\\x6a\\x5c",
      "mask": "xxxx",
      "offset": "0x0",
      "section": "text"
    },
    "near_call": {
      "pattern": "\\xe8",
      "mask": "x",
      "offset": "0x0",
      "section": "text"
    },
    "push_esi_call": {
      "pattern": "\\x56\\xe8",
      "mask": "xx",
      "offset": "0x0",
      "section": "text"
    }
  },
  "resolvers": {
    "decode_image_func": {
      "steps": [
        { "name": "scan_anchor", "op": "scan", "pattern": "decode_image_anchor", "out": "scan" },
        { "name": "to_function_start", "op": "to_function_start", "in": "scan", "out": "final" }
      ]
    },
    "open_file_by_file_id_func": {
      "steps": [
        { "name": "scan_anchor", "op": "scan", "pattern": "open_file_anchor", "out": "scan" },
        { "name": "to_function_start", "op": "to_function_start", "in": "scan", "scan_range": "0xfff", "out": "final" }
      ]
    },
    "allocate_image_func": {
      "steps": [
        { "name": "scan_pattern", "op": "scan", "pattern": "allocate_image_pattern", "out": "scan" },
        { "name": "to_function_start", "op": "to_function_start", "in": "scan", "out": "final" }
      ]
    },
    "depalletize_func": {
      "steps": [
        { "name": "scan_string", "op": "use_of_string", "literal": "destPalette", "nth": "1", "out": "scan" },
        { "name": "to_function_start", "op": "to_function_start", "in": "scan", "out": "final" }
      ]
    },
    "file_hash_to_rec_obj_func": {
      "steps": [
        { "name": "scan_anchor", "op": "scan", "pattern": "amet_data_anchor", "out": "anchor" },
        { "name": "find_call", "op": "find_in_range", "pattern": "near_call", "start": "anchor", "start_add": "0xc", "end": "anchor", "end_add": "0xff", "out": "callsite" },
        { "name": "resolve_target", "op": "function_from_near_call", "in": "callsite", "out": "final" }
      ]
    },
    "read_file_buffer_func": {
      "steps": [
        { "name": "scan_anchor", "op": "scan", "pattern": "amet_data_anchor", "out": "anchor" },
        { "name": "find_first_call", "op": "find_in_range", "pattern": "near_call", "start": "anchor", "start_add": "0xc", "end": "anchor", "end_add": "0xff", "out": "first_call" },
        { "name": "find_second_call", "op": "find_in_range", "pattern": "near_call", "start": "first_call", "start_add": "0x1", "end": "first_call", "end_add": "0xff", "out": "callsite" },
        { "name": "resolve_target", "op": "function_from_near_call", "in": "callsite", "out": "final" }
      ]
    },
    "close_rec_obj_func": {
      "steps": [
        { "name": "scan_compare", "op": "scan", "pattern": "amet_compare", "out": "anchor" },
        { "name": "find_call", "op": "find_in_range", "pattern": "push_esi_call", "start": "anchor", "start_add": "0x0", "end": "anchor", "end_add": "-0xff", "out": "push_site" },
        { "name": "advance_to_call", "op": "add", "in": "push_site", "value": "0x1", "out": "callsite" },
        { "name": "resolve_target", "op": "function_from_near_call", "in": "callsite", "out": "final" }
      ]
    },
    "free_file_buffer_func": {
      "steps": [
        { "name": "scan_compare", "op": "scan", "pattern": "amet_compare", "out": "anchor" },
        { "name": "find_first_call", "op": "find_in_range", "pattern": "push_esi_call", "start": "anchor", "start_add": "0x0", "end": "anchor", "end_add": "-0xff", "out": "first_push" },
        { "name": "find_second_call", "op": "find_in_range", "pattern": "push_esi_call", "start": "first_push", "start_add": "-0x1", "end": "first_push", "end_add": "-0xff", "out": "second_push" },
        { "name": "advance_to_call", "op": "add", "in": "second_push", "value": "0x1", "out": "callsite" },
        { "name": "resolve_target", "op": "function_from_near_call", "in": "callsite", "out": "final" }
      ]
    }
  }
}
