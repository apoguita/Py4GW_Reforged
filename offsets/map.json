      "section": "text"
    },
    "query_altitude_callsite": {
      "pattern": "\\xD9\\x06\\x8D\\x45\\xC8\\x83\\xC4\\x10",
      "mask": "xxxxxxxx",
      "offset": "-0x5",
      "section": "text"
    },
    "bypass_tolerance_patch": {
      "pattern": "\\x74\\x1D\\x68\\xA9\\x01\\x00\\x00",
      "mask": "xxxxxxx",
      "offset": "0",
