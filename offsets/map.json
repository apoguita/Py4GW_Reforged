    },
    "enter_challenge_anchor": {
      "pattern": "\\xA9\\x00\\x00\\x10\\x00\\x74\\x24",
      "mask": "xxxxxxx",
      "offset": "0",
      "section": "text"
    },
    "map_type_instance_infos_ref": {
      "pattern": "\\x83\\xC0\\x0C\\x41\\x3D\\x00\\x00\\x00\\x00",
      "mask": "xxxxx??xx",
      "offset": "0",
      "section": "text"
    },
    "world_map_ui_callback": {
      "pattern": "\\x83\\xE8\\x04\\x83\\xF8\\x52",
      "mask": "xxxxxx",
      "offset": "0",
      "section": "text"
    },
    "mission_map_ui_callback": {
      "pattern": "\\x08\\x3D\\x00\\x00\\x00\\x10",
      "mask": "xxxxxx",
      "offset": "0",
      "section": "text"
    },
    "near_call_opcode": {
      "pattern": "\\xE8",
      "mask": "x",
      "offset": "0",
      "section": "text"
    }
  },
  "resolvers": {
    "skip_cinematic_func": {
      "steps": [
        { "name": "scan_target", "op": "scan", "pattern": "skip_cinematic", "out": "final" }
      ]
    },
    "region_id_addr": {
      "steps": [
        { "name": "scan_ref", "op": "scan", "pattern": "region_id_ref", "out": "scan" },
        { "name": "deref_ptr", "op": "dereference", "in": "scan", "out": "final" }
      ]
    },
    "area_info_addr": {
      "steps": [
        { "name": "scan_ref", "op": "scan", "pattern": "area_info_ref", "out": "scan" },
        { "name": "deref_ptr", "op": "dereference", "in": "scan", "out": "candidate" },
        { "name": "validate_ptr", "op": "validate_section", "in": "candidate", "section": "rdata", "out": "final" }
      ]
    },
    "instance_info_addr": {
      "steps": [
        { "name": "scan_ref", "op": "scan", "pattern": "instance_info_ref", "out": "scan" },
        { "name": "deref_ptr", "op": "dereference", "in": "scan", "out": "final" }
      ]
    },
    "instance_info_ptr_ref": {
      "steps": [
        { "name": "scan_ref", "op": "scan", "pattern": "instance_info_ref", "out": "final" }
      ]
    },
    "query_altitude_func": {
      "steps": [
        { "name": "scan_callsite", "op": "scan", "pattern": "query_altitude_callsite", "out": "callsite" },
        { "name": "resolve_target", "op": "function_from_near_call", "in": "callsite", "out": "final" }
      ]
    },
    "bypass_tolerance_patch_addr": {
      "steps": [
        { "name": "scan_patch_addr", "op": "scan", "pattern": "bypass_tolerance_patch", "out": "final" }
      ]
    },
    "cancel_enter_challenge_mission_func": {
      "steps": [
        { "name": "scan_anchor", "op": "scan", "pattern": "enter_challenge_anchor", "out": "anchor" },
        { "name": "adjust_callsite", "op": "add", "in": "anchor", "value": "0x1B", "out": "callsite" },
        { "name": "resolve_target", "op": "function_from_near_call", "in": "callsite", "out": "final" }
      ]
    },
    "enter_challenge_mission_func": {
      "steps": [
        { "name": "scan_anchor", "op": "scan", "pattern": "enter_challenge_anchor", "out": "anchor" },
        { "name": "adjust_callsite", "op": "add", "in": "anchor", "value": "0x43", "out": "callsite" },
        { "name": "resolve_target", "op": "function_from_near_call", "in": "callsite", "out": "final" }
      ]
    },
    "map_type_instance_infos_ptr": {
      "steps": [
        { "name": "scan_anchor", "op": "scan", "pattern": "map_type_instance_infos_ref", "out": "anchor" },
        { "name": "pointer_ref", "op": "add", "in": "anchor", "value": "0x1A", "out": "pointer_ref" },
        { "name": "deref_ptr", "op": "dereference", "in": "pointer_ref", "out": "final" }
      ]
    },
    "map_type_instance_infos_size": {
      "steps": [
        { "name": "scan_anchor", "op": "scan", "pattern": "map_type_instance_infos_ref", "out": "anchor" },
        { "name": "size_ref", "op": "add", "in": "anchor", "value": "0x5", "out": "size_ref" },
        { "name": "read_size_bytes", "op": "read_u32", "in": "size_ref", "out": "size_bytes" },
        { "name": "divide_entry_size", "op": "divide", "in": "size_bytes", "value": "12", "out": "final" }
      ]
    },
    "world_map_ui_callback_func": {
      "steps": [
        { "name": "scan_target", "op": "scan", "pattern": "world_map_ui_callback", "out": "scan" },
        { "name": "to_function_start", "op": "to_function_start", "in": "scan", "out": "final" }
      ]
    },
    "mission_map_ui_callback_func": {
      "steps": [
        { "name": "scan_target", "op": "scan", "pattern": "mission_map_ui_callback", "out": "scan" },
        { "name": "to_function_start", "op": "to_function_start", "in": "scan", "out": "final" }
      ]
    }
  }
}
