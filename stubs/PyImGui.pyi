    def path_bezier_quadratic_curve_to(self, p2: Sequence[float], p3: Sequence[float], num_segments: int = 0) -> None: ...
    def path_rect(self, rect_min: Sequence[float], rect_max: Sequence[float], rounding: float = 0.0, flags: int = 0) -> None: ...
